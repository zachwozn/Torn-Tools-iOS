{
	"manifest_version": 3,
	"name": "TornTools",
	"description": "Several tools for Torn.",
	"version": "9.0.5",
	"icons": {
		"16": "icons/16.png",
		"32": "icons/32.png",
		"48": "icons/48.png",
		"128": "icons/128.png"
	},
	"author": "Gregor Kaljulaid - Mephiles[2087524]",
	"host_permissions": [
		"https://torn.com/"
	],
	"optional_host_permissions": [
		"https://www.tornstats.com/",
		"https://yata.yt/",
		"https://nuke.family/",
		"https://tornuhc.eu/",
		"https://api.no1irishstig.co.uk/",
		"https://prombot.co.uk/",
		"https://api.lzpt.io/",
		"https://what-the-f.de/",
		"https://weav3r.dev/*",
		"https://ffscouter.com/",
		"https://laekna-revive-bot.onrender.com/",
		"https://torn-intel.com/"
	],
	"permissions": [
		"storage",
		"notifications",
		"background",
		"alarms"
	],
	"web_accessible_resources": [
		{
			"resources": [
				"images/*",
				"*--inject.js",
				"*/*.js.map",
				"options.html"
			],
			"matches": [
				"https://*.torn.com/*"
			]
		}
	],
	"content_security_policy": {
		"extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
	},
	"background": {
		"scripts": [
			"safari-bridge.js",
			"background.js"
		]
	},
	"action": {
		"default_title": "TornTools - Popup",
		"default_popup": "popup.html"
	},
	"options_ui": {
		"open_in_tab": true,
		"page": "options.html"
	},
	"content_scripts": [
		{
			"matches": [
				"https://*.torn.com/api.html*"
			],
			"run_at": "document_end",
			"css": [
				"content-scripts/api-features.css"
			],
			"js": [
				"content-scripts/api-features.js"
			]
		},
		{
			"matches": [
				"https://*.torn.com/crimes.php*",
				"https://*.torn.com/item.php*"
			],
			"run_at": "document_start",
			"js": [
				"content-scripts/drag-drop-touch.js"
			]
		},
		{
			"matches": [
				"https://*.torn.com/*"
			],
			"exclude_matches": [
				"https://*.torn.com/api.html*",
				"https://*.torn.com/joblisting.php*",
				"https://*.torn.com/logout.php*",
				"https://*.torn.com/swagger.php*",
				"https://api.torn.com/*",
				"https://wiki.torn.com/*"
			],
			"run_at": "document_start",
			"css": [
				"content-scripts/extension.css"
			],
			"js": [
				"content-scripts/extension.js"
			]
		}
	]
}